# Local cache generated by Anzuanime
# =========================
cache/banners/
cache/characters/
cache/episodes/
cache/metadata/
cache/posters/
cache/subtitles/
cache/thumbnails/

# Local database and user data
cache/library.db
cache/library.db-*
cache/watch_history.json
cache/watch_history.json.bak
cache/watch_history.json.corrupt-*
cache/.watch_history.json.tmp-*
cache/watch_status.json
cache/watch_status.json.bak
cache/watch_status.json.corrupt-*
cache/.watch_status.json.tmp-*
cache/settings.json
cache/.watch_history.json.bak.tmp-*

# Optional temporary cache files
cache/*.tmp
cache/*.temp
cache/*.log

# Keep empty cache folder in GitHub
!cache/.gitkeep

