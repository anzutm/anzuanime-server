# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.venv/
env/

# =========================
# Local cache generated by AniBase
# =========================
cache/banners/
cache/characters/
cache/episodes/
cache/metadata/
cache/posters/
cache/seiyuu/
cache/subtitles/
cache/thumbnails/

# Local database and user data
cache/library.db
cache/library.db-*
cache/*.db
cache/*.db-*
cache/*.sqlite
cache/*.sqlite-*
cache/watch_history.json
cache/watch_history.json.bak
cache/watch_history.json.corrupt-*
cache/.watch_history.json.tmp-*
cache/.watch_history.json.bak.tmp-*
cache/watch_status.json
cache/watch_status.json.bak
cache/watch_status.json.corrupt-*
cache/.watch_status.json.tmp-*
cache/.watch_status.json.bak.tmp-*
cache/settings.json
cache/.settings.json.tmp-*

# Optional temporary cache files
cache/*.tmp
cache/*.temp
cache/*.log
cache/**/.*
cache/**/*.tmp
cache/**/*.temp
cache/**/*.part

# Keep empty cache folder in GitHub
!cache/.gitkeep

# =========================
# Local anime / movie folders
# =========================
Watchlist/
Ongoing/
Movies/
Anime/
Media/
Downloads/

# =========================
